# Copy to .env.backend in this directory (gitignored). Do not commit real secrets.
#
# ARK_API_KEY：若希望 .env.backend 长期保持模板占位符（避免误提交密钥），请复制本文件为
# .env.backend.local（同样已 gitignore），仅在该文件中写入真实 ARK_API_KEY；启动脚本与
# 后端进程会优先读取 .env.backend.local 中的密钥。

ARK_API_KEY=__PUT_NEW_KEY_HERE__
ARK_MODEL=doubao-seed-2-0-lite-260428
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 本地 Docker 开发库（docker compose 默认，见仓库根目录 docker-compose.yml；主机端口 3307）
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=aimap
DB_USER=aimap
DB_PASSWORD=aimap_dev

# 若使用本机已安装的 MySQL/GreatSQL 且占 3306，可改 DB_PORT=3306 及账号密码
